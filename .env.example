# ============================================
# wde - Environment Variables (Optional)
# ============================================
#
# Most configuration is done via `wde auth` command.
# Environment variables below are OPTIONAL overrides.
#
# Run `wde auth` to configure interactively (recommended)
# ============================================

# Override API keys (if not using config file)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GITHUB_TOKEN=ghp_...

# Ollama host (if not localhost)
# OLLAMA_HOST=http://localhost:11434
